# Async SQLAlchemy connection string (used by Alembic and app/db.py)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:54322/postgres

# Supabase project settings (used by app/database.py via Supabase client)
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-anon-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Talo Payments API
TALO_USER_ID=your-talo-user-id
TALO_CLIENT_ID=your-talo-client-id
TALO_CLIENT_SECRET=your-talo-client-secret
TALO_BASE_URL=https://sandbox-api.talo.com.ar
# Public URL that Talo will POST to when a transfer is received on a CVU.
# For local dev use ngrok: https://xxxx.ngrok.io/webhooks/talo
TALO_WEBHOOK_URL=https://your-domain.com/webhooks/talo

# API key for authenticating requests to the FastAPI backend (used by MCP server)
AGENTPAY_API_KEY=your-api-key-here

# MCP Server settings
MCP_HOST=0.0.0.0
MCP_PORT=8001
AGENTPAY_API_URL=http://localhost:8000

# External MP transfer microservice (Selenium); omit for mock executor in tests/dev
PAYMENTS_SERVICE_URL=http://localhost:8000
PAYMENTS_SERVICE_API_KEY=your-payments-api-key-here
PAYMENTS_SERVICE_TIMEOUT=60
